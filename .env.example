# RAG Website Chatbot Environment Variables

# FastAPI server settings
PORT=8000
HOST=0.0.0.0
DEBUG=True

# JWT Authentication secret key
JWT_SECRET=replace_with_a_secure_random_string_32_chars_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM APIs (leave blank to configure later via UI Settings)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Default settings
DEFAULT_CHUNK_SIZE=500
DEFAULT_CHUNK_OVERLAP=50
DEFAULT_TOP_K=5
DEFAULT_TEMPERATURE=0.2
DEFAULT_MAX_CRAWL_DEPTH=1
DEFAULT_MAX_PAGES=20

# Storage folders
DATA_DIR=./data
FAISS_DIR=./data/faiss
UPLOADS_DIR=./data/uploads
